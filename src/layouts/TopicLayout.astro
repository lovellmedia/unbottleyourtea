---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';

export interface Props {
  title: string;
  description: string;
  currentPage: string;
  canonicalURL?: URL;
}

const { title, description, currentPage, canonicalURL } = Astro.props;
---

<BaseLayout title={title} description={description} canonicalURL={canonicalURL}>
  <main class="px-6 md:px-20 lg:px-40 py-10 flex flex-col md:flex-row gap-12">
    <Sidebar currentPage={currentPage} />
    <div class="flex-1 max-w-3xl">
      <!-- Breadcrumbs -->
      <div class="flex items-center gap-2 text-[10px] uppercase tracking-[0.2em] font-bold text-slate-400 mb-8">
        <a class="hover:text-primary transition-colors" href="/">Home</a>
        <span>/</span>
        <a class="hover:text-primary transition-colors" href="/tea-etiquette-trends-technical-vocabulary/">Tea Guide</a>
        <span>/</span>
        <span class="text-primary">{currentPage === 'index' ? 'Overview' : currentPage.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}</span>
      </div>
      <slot />
    </div>
  </main>
</BaseLayout>
