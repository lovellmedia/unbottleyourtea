    },
    {
        id: 'ontology',
        title: 'Ontology',
        description: 'Understand tea plant varieties, oxidation levels, processing methods, and professional tasting vocabulary. Build your knowledge of Camellia sinensis cultivars, terroir influences, and the terminology used by tea masters worldwide.',
        href: `/${topicSlug}/ontology/`,
    },
    {
        id: 'trends',
        title: 'Trends',
        description: 'Explore current movements in specialty tea, sustainability, cold brew innovations, and market forecasts. Stay informed about the evolving landscape of tea consumption, from matcha lattes to blockchain-tracked supply chains.',
        href: `/${topicSlug}/trends/`,
    },
    {
        id: 'tools',
        title: 'Tools',
        description: 'Essential teaware guide covering kyusu, chasen, variable kettles, and brewing equipment for every style. From traditional Chinese gaiwans to modern precision brewers, discover the instruments that elevate your tea practice.',
