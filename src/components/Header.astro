---
const { title, subtitle } = Astro.props;
---

<header class="flex flex-col border-b border-primary/20 bg-background-light dark:bg-background-dark px-6 md:px-20 lg:px-40 py-6">
  <div class="flex items-center justify-between whitespace-nowrap pb-6">
    <a href="/" class="flex items-center gap-4 text-primary">
      <div class="size-8 flex items-center justify-center border-2 border-primary rounded-sm">
        <span class="material-symbols-outlined text-2xl">emoji_food_beverage</span>
      </div>
      <div class="flex flex-col">
        <h1 class="text-xl font-bold leading-none tracking-tight uppercase">Unbottle Your Tea</h1>
        <span class="text-[10px] tracking-[0.2em] font-medium opacity-70 uppercase">Tea Etiquette & Trends</span>
      </div>
    </a>
    <div class="hidden md:flex items-center gap-8">
      <a class="text-slate-800 dark:text-slate-200 text-sm font-medium hover:text-primary transition-colors uppercase tracking-wider" href="/tea-etiquette-trends-technical-vocabulary/">Overview</a>
      <a class="text-slate-800 dark:text-slate-200 text-sm font-medium hover:text-primary transition-colors uppercase tracking-wider" href="/tea-etiquette-trends-technical-vocabulary/history/">History</a>
      <a class="text-slate-800 dark:text-slate-200 text-sm font-medium hover:text-primary transition-colors uppercase tracking-wider" href="/tea-etiquette-trends-technical-vocabulary/trends/">Trends</a>
    </div>
  </div>
  {title && (
    <div class="flex flex-wrap justify-between items-end gap-6 pt-6 border-t border-primary/10">
      <div class="max-w-2xl">
        <h2 class="text-primary text-4xl md:text-5xl font-serif italic font-light leading-tight">{title}</h2>
        {subtitle && <p class="text-slate-600 dark:text-slate-400 text-lg font-normal mt-2 italic">{subtitle}</p>}
      </div>
    </div>
  )}
</header>
